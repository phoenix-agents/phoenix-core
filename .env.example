# Phoenix Core Environment Variables
# Copy this file to .env and fill in your actual API keys

# DashScope API (coding-plan provider)
# Used for: skill extraction, evolution, reflection, knowledge graph
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope Coding Plan API (alternative)
# Used for: advanced coding tasks
DASHSCOPE_CODING_PLAN_API_KEY=your_dashscope_coding_plan_api_key_here

# CompShare API
# Used for: multi-model access (GPT, Claude, DeepSeek, etc.)
COMPSHARE_API_KEY=your_compshare_api_key_here

# Moonshot API
# Used for: Kimi models
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Phoenix Core Configuration
# Optional: Override default workspace directory
# PHOENIX_WORKSPACES_DIR=/path/to/your/workspaces

# Optional: Enable debug logging
# PHOENIX_LOG_LEVEL=DEBUG

# ============================================
# 远程调试配置 (Remote Debug Configuration)
# ============================================
# 启用远程调试后，此设备会主动连接到中央调试服务器
# 中央服务器管理员可以查看日志、推送代码、执行命令

# 中央调试服务器地址 (格式：host:port 或 http://host:port)
# 配置此项即可启用远程调试，设备 ID 会自动生成
DEBUG_MASTER_URL=localhost:9000

# 此设备的唯一标识符 (可选，不配置则自动生成)
# 自动生成规则：phoenix-{主机名}-{MAC 地址前缀}
# 例如：phoenix-myserver-a1b2c3
# DEBUG_DEVICE_ID=phoenix-device-001

# 认证 Token (可选，如果中央服务器配置了 auth)
# DEBUG_AUTH_TOKEN=your_auth_token_here

# 示例配置 (远程设备):
# DEBUG_MASTER_URL=your-server.com:9000
# DEBUG_DEVICE_ID=beijing-office-phoenix  # 可选，不配则自动生成

# 示例配置 (中央服务器管理员):
# 访问 http://your-server.com:9000/debug 查看设备管理界面
